diff --git a/modules/highgui/CMakeLists.txt b/modules/highgui/CMakeLists.txt
index ae9c49c..6bec212 100644
--- a/modules/highgui/CMakeLists.txt
+++ b/modules/highgui/CMakeLists.txt
@@ -49,6 +49,19 @@ list(REMOVE_ITEM highgui_ext_hdrs "${CMAKE_CURRENT_LIST_DIR}/include/opencv2/${n
 
 set(OPENCV_HIGHGUI_BUILTIN_BACKEND "")
 
+# Build the Qt window backend as a dynamically loaded plugin (opencv_highgui_qt)
+# instead of linking it into the highgui module, when Qt is requested in
+# HIGHGUI_PLUGIN_LIST. This keeps libopencv_highgui free of any Qt dependency;
+# Qt is only needed at runtime when the plugin (and the Qt libraries) is present.
+set(__build_qt_plugin 0)
+if(HAVE_QT AND (
+    HIGHGUI_PLUGIN_LIST STREQUAL "all"
+    OR "qt" IN_LIST HIGHGUI_PLUGIN_LIST
+    OR "qt${QT_VERSION_MAJOR}" IN_LIST HIGHGUI_PLUGIN_LIST
+  ))
+  set(__build_qt_plugin 1)
+endif()
+
 if(WITH_FRAMEBUFFER AND HAVE_FRAMEBUFFER)
   set(OPENCV_HIGHGUI_BUILTIN_BACKEND "FB")
   add_definitions(-DHAVE_FRAMEBUFFER)
@@ -84,7 +97,7 @@ if(WITH_WAYLAND AND HAVE_WAYLAND)
   endif()
 
   ocv_module_include_directories(${WAYLAND_CLIENT_INCLUDE_DIRS} ${XKBCOMMON_INCLUDE_DIRS})
-elseif(HAVE_QT)
+elseif(HAVE_QT AND NOT __build_qt_plugin)
   set(OPENCV_HIGHGUI_BUILTIN_BACKEND "QT${QT_VERSION_MAJOR}")
   add_definitions(-DHAVE_QT)
 
@@ -184,7 +197,7 @@ elseif(WINRT)
     message(STATUS "  ${name}:   Removing 'comctl32.lib, gdi32.lib, ole32.lib, setupapi.lib'")
     message(STATUS "  ${name}:   Leaving '${HIGHGUI_LIBRARIES}'")
   endif()
-elseif(HAVE_COCOA)
+elseif(HAVE_COCOA AND NOT __build_qt_plugin)
   set(OPENCV_HIGHGUI_BUILTIN_BACKEND "COCOA")
   add_definitions(-DHAVE_COCOA)
   list(APPEND highgui_srcs ${CMAKE_CURRENT_LIST_DIR}/src/window_cocoa.mm)
@@ -194,7 +207,7 @@ endif()
 if(TARGET ocv.3rdparty.win32ui)
   if("win32ui" IN_LIST HIGHGUI_PLUGIN_LIST OR HIGHGUI_PLUGIN_LIST STREQUAL "all")
     ocv_create_builtin_highgui_plugin(opencv_highgui_win32 ocv.3rdparty.win32ui "window_w32.cpp")
-  elseif(NOT OPENCV_HIGHGUI_BUILTIN_BACKEND)
+  elseif(NOT OPENCV_HIGHGUI_BUILTIN_BACKEND AND NOT __build_qt_plugin)
     set(OPENCV_HIGHGUI_BUILTIN_BACKEND "WIN32UI")
     list(APPEND highgui_srcs ${CMAKE_CURRENT_LIST_DIR}/src/window_w32.cpp)
     list(APPEND tgts ocv.3rdparty.win32ui)
@@ -262,6 +275,71 @@ if(TARGET ocv.3rdparty.gtk3 OR TARGET ocv.3rdparty.gtk2)
   endif()
 endif()
 
+if(__build_qt_plugin)
+  # Custom plugin target for Qt. We cannot reuse ocv_create_builtin_highgui_plugin
+  # because the Qt backend needs MOC/RCC generated sources and several Qt targets.
+  message(STATUS "HighGUI: add builtin plugin 'opencv_highgui_qt' (QT${QT_VERSION_MAJOR})")
+  set(CMAKE_INCLUDE_CURRENT_DIR ON)
+  if(QT_VERSION_MAJOR EQUAL 6)
+    QT6_ADD_RESOURCES(_QT_PLUGIN_RCC ${CMAKE_CURRENT_LIST_DIR}/src/window_QT.qrc)
+    QT6_WRAP_CPP(_QT_PLUGIN_MOC ${CMAKE_CURRENT_LIST_DIR}/src/window_QT.h)
+  else()
+    QT5_ADD_RESOURCES(_QT_PLUGIN_RCC ${CMAKE_CURRENT_LIST_DIR}/src/window_QT.qrc)
+    QT5_WRAP_CPP(_QT_PLUGIN_MOC ${CMAKE_CURRENT_LIST_DIR}/src/window_QT.h)
+  endif()
+
+  add_library(opencv_highgui_qt MODULE
+    ${CMAKE_CURRENT_LIST_DIR}/src/window_QT.cpp
+    ${CMAKE_CURRENT_LIST_DIR}/src/window_QT.h
+    ${_QT_PLUGIN_MOC}
+    ${_QT_PLUGIN_RCC})
+  target_include_directories(opencv_highgui_qt PRIVATE "${CMAKE_CURRENT_BINARY_DIR}")
+  target_compile_definitions(opencv_highgui_qt PRIVATE BUILD_PLUGIN HAVE_QT)
+  if(QT_VERSION_MAJOR EQUAL 6)
+    target_compile_definitions(opencv_highgui_qt PRIVATE HAVE_QT6)
+  endif()
+
+  set(__qt_plugin_deps Core Gui Widgets Test Concurrent)
+  if(HAVE_QT_OPENGL)
+    target_compile_definitions(opencv_highgui_qt PRIVATE HAVE_QT_OPENGL)
+    if(QT_VERSION_MAJOR GREATER 5)
+      list(APPEND __qt_plugin_deps OpenGLWidgets)
+    endif()
+    list(APPEND __qt_plugin_deps OpenGL)
+    if(OPENGL_LIBRARIES)
+      target_link_libraries(opencv_highgui_qt PRIVATE ${OPENGL_LIBRARIES})
+    endif()
+  endif()
+  foreach(dt_dep ${__qt_plugin_deps})
+    # Link the canonical Qt imported targets (Qt6::Core, Qt6::Widgets, ...),
+    # which carry both the libraries and the include directories. The bare
+    # ${Qt6Core} variable used by the builtin path is not set here.
+    target_link_libraries(opencv_highgui_qt PRIVATE Qt${QT_VERSION_MAJOR}::${dt_dep})
+  endforeach()
+
+  foreach(mod opencv_highgui opencv_core opencv_imgproc opencv_imgcodecs opencv_videoio)
+    ocv_target_link_libraries(opencv_highgui_qt LINK_PRIVATE ${mod})
+    ocv_target_include_directories(opencv_highgui_qt "${OPENCV_MODULE_${mod}_LOCATION}/include")
+  endforeach()
+
+  set_target_properties(opencv_highgui_qt PROPERTIES
+    CXX_STANDARD 17
+    CXX_STANDARD_REQUIRED ON
+    CXX_VISIBILITY_PRESET hidden
+    DEBUG_POSTFIX "${OPENCV_DEBUG_POSTFIX}"
+    OUTPUT_NAME "opencv_highgui_qt")
+
+  if(WIN32)
+    set_target_properties(opencv_highgui_qt PROPERTIES LIBRARY_OUTPUT_DIRECTORY ${EXECUTABLE_OUTPUT_PATH})
+    install(TARGETS opencv_highgui_qt OPTIONAL LIBRARY DESTINATION ${OPENCV_BIN_INSTALL_PATH} COMPONENT plugins)
+  else()
+    install(TARGETS opencv_highgui_qt OPTIONAL LIBRARY DESTINATION ${OPENCV_LIB_INSTALL_PATH} COMPONENT plugins)
+  endif()
+  if(TARGET opencv_highgui_plugins)
+    add_dependencies(opencv_highgui_plugins opencv_highgui_qt)
+  endif()
+endif()
+
 if(NOT OPENCV_HIGHGUI_BUILTIN_BACKEND)
   set(OPENCV_HIGHGUI_BUILTIN_BACKEND "NONE")
 endif()
