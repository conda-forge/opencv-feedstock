diff --git a/modules/cvv/src/cvv_forward.cpp b/modules/cvv/src/cvv_forward.cpp
new file mode 100644
index 0000000..5de6a43
--- /dev/null
+++ b/modules/cvv/src/cvv_forward.cpp
@@ -0,0 +1,169 @@
+// This file is part of OpenCV project.
+// It is subject to the license terms in the LICENSE file found in the top-level
+// directory of this distribution and at http://opencv.org/license.html.
+
+// Qt-free forwarder implementations of the cvv public entry points. These are
+// the symbols exported by the lightweight opencv_cvv module (which is part of
+// the Qt-free libopencv). The real Qt debug-visualization GUI lives in the
+// opencv_cvv_qt plugin; it is loaded on first use. When the plugin (or Qt) is
+// not available the cvv calls become no-ops, so opencv stays usable headless.
+
+#include "opencv2/cvv/show_image.hpp"
+#include "opencv2/cvv/dmatch.hpp"
+#include "opencv2/cvv/filter.hpp"
+#include "opencv2/cvv/final_show.hpp"
+#include "opencv2/core/utils/logger.hpp"
+
+#include "cvv_plugin_api.hpp"
+
+#include <string>
+#include <utility>
+#include <vector>
+
+#if defined(_WIN32)
+#include <windows.h>
+#else
+#include <dlfcn.h>
+#endif
+
+namespace cvv { namespace impl {
+
+namespace {
+
+// A marker whose address lives in this (opencv_cvv) library, used to locate the
+// library on disk so the plugin can be found next to it regardless of the
+// runtime library search path.
+void cvvForwardMarker() {}
+
+std::string ownDirectory()
+{
+#if defined(_WIN32)
+    HMODULE self = NULL;
+    if (GetModuleHandleExA(GET_MODULE_HANDLE_EX_FLAG_FROM_ADDRESS |
+                           GET_MODULE_HANDLE_EX_FLAG_UNCHANGED_REFCOUNT,
+                           reinterpret_cast<LPCSTR>(&cvvForwardMarker), &self) && self)
+    {
+        char path[1024] = {0};
+        if (GetModuleFileNameA(self, path, sizeof(path)))
+        {
+            std::string p(path);
+            const size_t pos = p.find_last_of("\\/");
+            if (pos != std::string::npos)
+                return p.substr(0, pos);
+        }
+    }
+#else
+    Dl_info info;
+    if (dladdr(reinterpret_cast<void*>(&cvvForwardMarker), &info) && info.dli_fname)
+    {
+        std::string p(info.dli_fname);
+        const size_t pos = p.find_last_of('/');
+        if (pos != std::string::npos)
+            return p.substr(0, pos);
+    }
+#endif
+    return std::string();
+}
+
+const CvvPluginAPI* loadCvvPlugin()
+{
+    // Loaded once, cached for the lifetime of the process.
+    static const CvvPluginAPI* const g_api = []() -> const CvvPluginAPI*
+    {
+        const std::string dir = ownDirectory();
+        const std::string sep =
+#if defined(_WIN32)
+            "\\";
+#else
+            "/";
+#endif
+        static const char* const leaf_names[] = {
+#if defined(_WIN32)
+            "opencv_cvv_qt.dll",
+#elif defined(__APPLE__)
+            // OpenCV builds plugins as loadable modules, which are .so on macOS.
+            "libopencv_cvv_qt.so", "libopencv_cvv_qt.dylib",
+#else
+            "libopencv_cvv_qt.so",
+#endif
+        };
+
+        std::vector<std::string> candidates;
+        for (const char* leaf : leaf_names)
+        {
+            if (!dir.empty())
+                candidates.push_back(dir + sep + leaf);  // next to opencv_cvv (robust)
+            candidates.push_back(leaf);                  // fall back to the loader search path
+        }
+
+        typedef const CvvPluginAPI* (CV_API_CALL *init_fn_t)(int);
+        for (const std::string& name : candidates)
+        {
+#if defined(_WIN32)
+            HMODULE handle = LoadLibraryA(name.c_str());
+            if (!handle)
+                continue;
+            init_fn_t init = reinterpret_cast<init_fn_t>(
+                    reinterpret_cast<void*>(GetProcAddress(handle, "opencv_cvv_plugin_init_v0")));
+#else
+            void* handle = dlopen(name.c_str(), RTLD_NOW | RTLD_GLOBAL);
+            if (!handle)
+                continue;
+            init_fn_t init = reinterpret_cast<init_fn_t>(
+                    dlsym(handle, "opencv_cvv_plugin_init_v0"));
+#endif
+            if (init)
+            {
+                const CvvPluginAPI* api = init(0);
+                if (api)
+                {
+                    CV_LOG_INFO(NULL, "cvv: loaded Qt debug-visualization plugin '" << name << "'");
+                    return api;
+                }
+            }
+        }
+        CV_LOG_WARNING(NULL, "cvv: the Qt debug-visualization plugin (opencv_cvv_qt) is not "
+                             "available; cvv calls are no-ops. Install the py-opencv package "
+                             "(and qt6) to enable the cvv debug GUI.");
+        return nullptr;
+    }();
+    return g_api;
+}
+
+}  // namespace
+
+void showImage(cv::InputArray img, const CallMetaData& data,
+               const char* description, const char* view)
+{
+    const CvvPluginAPI* api = loadCvvPlugin();
+    if (api && api->showImage)
+        api->showImage(img, data, description, view);
+}
+
+void debugDMatch(cv::InputArray img1, std::vector<cv::KeyPoint> keypoints1,
+                 cv::InputArray img2, std::vector<cv::KeyPoint> keypoints2,
+                 std::vector<cv::DMatch> matches, const CallMetaData& data,
+                 const char* description, const char* view, bool useTrainDescriptor)
+{
+    const CvvPluginAPI* api = loadCvvPlugin();
+    if (api && api->debugDMatch)
+        api->debugDMatch(img1, std::move(keypoints1), img2, std::move(keypoints2),
+                         std::move(matches), data, description, view, useTrainDescriptor);
+}
+
+void debugFilter(cv::InputArray original, cv::InputArray result,
+                 const CallMetaData& data, const char* description, const char* view)
+{
+    const CvvPluginAPI* api = loadCvvPlugin();
+    if (api && api->debugFilter)
+        api->debugFilter(original, result, data, description, view);
+}
+
+void finalShow()
+{
+    const CvvPluginAPI* api = loadCvvPlugin();
+    if (api && api->finalShow)
+        api->finalShow();
+}
+
+}} // namespace cvv::impl
diff --git a/modules/cvv/src/cvv_plugin_api.hpp b/modules/cvv/src/cvv_plugin_api.hpp
new file mode 100644
index 0000000..9a5b0d1
--- /dev/null
+++ b/modules/cvv/src/cvv_plugin_api.hpp
@@ -0,0 +1,54 @@
+// This file is part of OpenCV project.
+// It is subject to the license terms in the LICENSE file found in the top-level
+// directory of this distribution and at http://opencv.org/license.html.
+
+#ifndef OPENCV_CVV_PLUGIN_API_HPP
+#define OPENCV_CVV_PLUGIN_API_HPP
+
+// Internal ABI shared between the Qt-free forwarder library (opencv_cvv) and the
+// Qt debug-visualization plugin (opencv_cvv_qt). The plugin exposes the four
+// Qt-backed cvv entry points through this small table; the forwarder dlopen's
+// the plugin and forwards to it. Both libraries are produced by the same OpenCV
+// build, so passing C++ types across the boundary is ABI-safe.
+
+#include <vector>
+
+#include "opencv2/core.hpp"
+#include "opencv2/core/llapi/llapi.h"
+#include "opencv2/features2d.hpp"
+#include "opencv2/cvv/call_meta_data.hpp"
+
+namespace cvv { namespace impl {
+
+struct CvvPluginAPI
+{
+    int api_version;  // == 0
+
+    void (*showImage)(cv::InputArray img, const CallMetaData& data,
+                      const char* description, const char* view);
+
+    void (*debugDMatch)(cv::InputArray img1, std::vector<cv::KeyPoint> keypoints1,
+                        cv::InputArray img2, std::vector<cv::KeyPoint> keypoints2,
+                        std::vector<cv::DMatch> matches, const CallMetaData& data,
+                        const char* description, const char* view,
+                        bool useTrainDescriptor);
+
+    void (*debugFilter)(cv::InputArray original, cv::InputArray result,
+                        const CallMetaData& data, const char* description,
+                        const char* view);
+
+    void (*finalShow)();
+};
+
+}} // namespace cvv::impl
+
+extern "C" {
+
+// Implemented by the opencv_cvv_qt plugin. Returns NULL if the requested API
+// version is not supported.
+CV_PLUGIN_EXPORTS const cvv::impl::CvvPluginAPI* opencv_cvv_plugin_init_v0(
+        int requested_api_version) CV_NOEXCEPT;
+
+}  // extern "C"
+
+#endif  // OPENCV_CVV_PLUGIN_API_HPP
