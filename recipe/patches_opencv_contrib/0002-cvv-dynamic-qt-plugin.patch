@@ -0,0 +1,29 @@
+// This file is part of OpenCV project.
+// It is subject to the license terms in the LICENSE file found in the top-level
+// directory of this distribution and at http://opencv.org/license.html.
+
+// Entry point of the opencv_cvv_qt plugin. It hands the Qt-free opencv_cvv
+// forwarder library a table of the real (Qt-backed) cvv implementations defined
+// in this plugin. Built with CVV_BUILD_PLUGIN, so the cvv::impl::* symbols are
+// hidden here and do not collide with the forwarders of the same name.
+
+#include "opencv2/cvv/show_image.hpp"
+#include "opencv2/cvv/dmatch.hpp"
+#include "opencv2/cvv/filter.hpp"
+#include "opencv2/cvv/final_show.hpp"
+
+#include "cvv_plugin_api.hpp"
+
+extern "C" CV_PLUGIN_EXPORTS const cvv::impl::CvvPluginAPI* opencv_cvv_plugin_init_v0(
+        int /*requested_api_version*/) CV_NOEXCEPT
+{
+    static const cvv::impl::CvvPluginAPI api =
+    {
+        /* api_version */ 0,
+        cvv::impl::showImage,
+        cvv::impl::debugDMatch,
+        cvv::impl::debugFilter,
+        cvv::impl::finalShow,
+    };
+    return &api;
+}
